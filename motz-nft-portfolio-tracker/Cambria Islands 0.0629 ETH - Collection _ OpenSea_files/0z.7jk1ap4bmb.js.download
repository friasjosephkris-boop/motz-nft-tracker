                  contractAddress
                  chainIdentifier
                  symbol
                  decimals
                  warnings {
                    featureId
                  }
                  ...CurrencyV2Lockup
                }
              }
              pricePerFromAsset {
                usd
              }
              pricePerToAsset {
                usd
              }
              ...readSwapImpact
            }
          }
          ...SwapDetails
          ...useTrackSwapEvent
          ...useSwapGasCheckFragment
        }
        swapActions {
          errors {
            __typename
            ... on UnsupportedSwapError {
              message
            }
            ... on SwapProvidersUnavailableError {
              message
            }
          }
          actions {
            __typename
            ...ActionTimeline
            ...useActionsNetworkFees_action
          }
        }
      }
    }
