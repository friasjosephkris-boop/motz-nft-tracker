      $recipient: Address
      $requestId: UUID
      $capabilities: WalletCapabilities
      $walletType: String
      $useExactApprovalAmount: Boolean
    ) {
      tokenSwap(
        fromAssets: $fromAssets
        toAssets: $toAssets
        address: $address
        slippageTolerance: $slippageTolerance
        recipient: $recipient
        requestId: $requestId
        capabilities: $capabilities
        walletType: $walletType
        useExactApprovalAmount: $useExactApprovalAmount
      ) {
        quote {
          slippageTolerance
          swapRoutes {
            __typename
            ... on SwapRoute {
              swapProvider
              toQuantity
              fromQuantity
              toAsset {
                __typename
