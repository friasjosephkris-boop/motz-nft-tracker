        representativeItem {
          imageUrl
        }
        numItems
        price {
          ...TokenPrice
        }
        occurredAt
        isRead
      }
      ... on RewardReadyToClaimNotification {
        quest {
          type
          tier
        }
        occurredAt
        isRead
      }
      ... on MintNotification {
        numItems
        collection {
          name
          imageUrl
        }
        occurredAt
        isRead
      }
      ... on DropStageReminderNotification {
        collection {
          name
          imageUrl
          slug
        }
        stageStartTime
        occurredAt
        isRead
      }
      ... on ShipmentReceivedNotification {
        shipmentId
        shipmentName
        shipmentDescription
        occurredAt
        isRead
      }
      ... on OfferReceivedNotification {
        item {
          imageUrl
          name
          ...itemUrl
        }
        price {
          ...TokenPrice
        }
        occurredAt
        isRead
        expireAt
      }
      ... on CollectionOfferReceivedNotification {
        representativeItem {
          imageUrl
          name
          ...itemUrl
        }
        price {
          ...TokenPrice
        }
        occurredAt
        isRead
        expireAt
      }
      ... on PerpLiquidationWarningNotification {
        coin
        isLong
        perpetualFuture {
          symbol
          imageUrl
        }
        occurredAt
        isRead
      }
    }
  `,[s.TokenPriceFragment,a.itemUrlFragment]);e.s(["useNotificationFragment",0,o],871544);let l=(0,r.graphql)(`
