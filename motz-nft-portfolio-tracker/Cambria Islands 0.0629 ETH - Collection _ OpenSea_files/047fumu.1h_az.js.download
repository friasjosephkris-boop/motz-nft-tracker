        item {
          imageUrl
          name
          ...itemUrl
        }
        price {
          ...TokenPrice
        }
        occurredAt
        isRead
      }
      ... on BulkPurchaseNotification {
        representativeItem {
          imageUrl
        }
        numItems
        price {
          ...TokenPrice
        }
        occurredAt
        isRead
      }
