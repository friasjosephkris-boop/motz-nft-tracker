# Wagmi 3.x is installed alongside @rainbow-me/rainbowkit@2.x which
# peer-depends on wagmi@^2.9.0. The actual integration works at runtime
# (we use the wagmi APIs that overlap both major versions), but strict
# peer-dep resolution rejects the install. Vercel's npm runs strict;
# this lets it match the local dev install behaviour.
legacy-peer-deps=true
